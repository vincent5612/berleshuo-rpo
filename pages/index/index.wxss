.home {
  min-height: 100vh; background: #f5f6f8;
  display: flex; flex-direction: column; align-items: center;
  padding: 36px 20px 20px;
  box-sizing: border-box;
}
.hero { text-align: center; margin-bottom: 28px; }
.hero-title { font-size: 36px; font-weight: 800; color: #1e293b; display: block; }
.hero-sub { font-size: 24px; font-weight: 700; color: #d97706; display: block; margin-top: 4px; }
.hero-desc { font-size: 14px; color: #64748b; display: block; margin-top: 8px; }

.features { width: 100%; max-width: 360px; }
.feature {
  background: #ffffff; border-radius: 14px; padding: 20px;
  margin-bottom: 14px; border: 1px solid #e2e8f0; box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  text-align: center;
}
.f-icon { font-size: 32px; display: block; margin-bottom: 8px; }
.f-title { font-size: 18px; font-weight: 700; color: #1e293b; display: block; }
.f-desc { font-size: 13px; color: #64748b; display: block; margin-top: 4px; line-height: 1.5; }

.tips {
  width: 100%; max-width: 360px; margin-top: 6px;
  background: #fef3c7; border-radius: 12px; padding: 14px 16px;
  box-sizing: border-box;
}
.tips-title { font-size: 13px; font-weight: 600; color: #1e293b; display: block; margin-bottom: 6px; }
.tip-item { font-size: 12px; color: #64748b; display: block; line-height: 1.8; }

.version { font-size: 11px; color: #94a3b8; margin-top: 12px; }
