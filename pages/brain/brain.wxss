.brain-page {
  min-height: 100vh; background: #f5f6f8;
  padding: 20px 16px 30px; box-sizing: border-box;
}
.header { text-align: center; margin-bottom: 24px; }
.h-title { font-size: 28px; font-weight: 800; color: #1e293b; display: block; }
.h-sub { font-size: 14px; color: #64748b; display: block; margin-top: 4px; }

.section {
  background: #ffffff; border-radius: 14px; padding: 16px;
  margin-bottom: 12px; border: 1px solid #e2e8f0;
  display: flex; align-items: flex-start; gap: 12px;
}
.s-num {
  font-size: 20px; font-weight: 800; color: #d97706;
  flex-shrink: 0; width: 36px; text-align: center; line-height: 1.4;
}
.s-body { flex: 1; }
.s-title { font-size: 16px; font-weight: 700; color: #1e293b; display: block; margin-bottom: 4px; }
.s-desc { font-size: 13px; color: #64748b; display: block; line-height: 1.6; }
.s-tag { font-size: 12px; color: #d97706; display: block; margin-top: 6px; }

.formula-box {
  background: #fef3c7; border-radius: 12px; padding: 16px;
  margin: 16px 0; text-align: center;
  border: 1px solid #fde68a;
}
.formula-label { font-size: 12px; color: #92400e; display: block; margin-bottom: 6px; }
.formula-text { font-size: 20px; font-weight: 700; color: #1e293b; letter-spacing: 2px; }

.footer-bar {
  display: flex; justify-content: center; gap: 16px;
  margin-top: 8px;
}
.footer-btn {
  font-size: 14px; color: #d97706; font-weight: 600;
  padding: 8px 0;
}
